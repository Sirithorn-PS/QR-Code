generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   Int           @id @default(autoincrement())
  username             String        @unique
  password             String
  fullName             String
  role                 String        @default("warehouse_staff")
  createdAt            DateTime      @default(now())
  approvedTransactions Transaction[] @relation("ApprovedTransactions")
  createdTransactions  Transaction[] @relation("CreatedTransactions")
}

model Product {
  id           Int           @id @default(autoincrement())
  itemCode     String        @unique
  description  String
  unit         String
  warehouse    String
  location     String
  quantity     Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  productId    String?
  itemType     String        @default("FG")
  transactions Transaction[]

  @@index([itemCode])
  @@index([itemType])
}

model BillOfMaterial {
  id                Int      @id @default(autoincrement())
  parentItemCode    String
  componentItemCode String
  description       String
  uom               String
  quantity          Float
  warehouse         String
  depth             Int
  bomType           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([parentItemCode])
  @@index([componentItemCode])
  @@index([parentItemCode, depth])
}

model Transaction {
  id           Int       @id @default(autoincrement())
  productId    Int
  type         String
  quantity     Float
  status       String    @default("pending")
  itemSnapshot Json
  note         String?
  createdById  Int
  approvedById Int?
  createdAt    DateTime  @default(now())
  confirmedAt  DateTime?
  rejectedAt   DateTime?
  approvedBy   User?     @relation("ApprovedTransactions", fields: [approvedById], references: [id])
  createdBy    User      @relation("CreatedTransactions", fields: [createdById], references: [id])
  product      Product   @relation(fields: [productId], references: [id])
}
